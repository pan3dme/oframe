<!--features.wxml-->
<navigation-bar title="功能列表" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <!-- 功能面板 -->
  <view class="feature-panel">
    <view class="feature-title">功能列表</view>
    <view class="feature-grid">
      <view class="feature-btn" wx:for="{{featureBtns}}" wx:key="id" bindtap="onFeatureTap" data-id="{{item.id}}">
        <view class="feature-num">{{item.id}}</view>
        <view class="feature-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <!-- 表格显示 -->
  <view class="msg-panel" wx:if="{{showRecordTable}}">
    <view class="record-table">
      <view class="table-header">
        <view class="th th-deviceId">deviceId</view>
        <view class="th th-lorastr">lorastr</view>
        <view class="th th-time">time</view>
      </view>
      <view class="table-body">
        <view class="table-row" wx:for="{{recordList}}" wx:key="date">
          <view class="td td-deviceId">{{item.deviceId}}</view>
          <view class="td td-lorastr">{{item.lorastr}}</view>
          <view class="td td-time">
            <view class="time-date">{{item.date}}</view>
            <view class="time-clock">{{item.time_part}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 接收到的消息 -->
  <view class="msg-panel" wx:if="{{receivedMsg && !showRecordTable}}">
    <view class="msg-label">📩 收到消息：</view>
    <view class="msg-content">{{receivedMsg}}</view>
  </view>
</scroll-view>

<!-- 插入记录弹窗 -->
<view class="track-modal" wx:if="{{showInsertModal}}">
  <view class="track-mask" bindtap="onInsertClose"></view>
  <view class="track-dialog">
    <view class="track-close" bindtap="onInsertClose">✕</view>
    <view class="track-title">插入一条记录</view>
    <view class="track-subtitle">请输入设备ID（deviceId）</view>
    <input class="track-input" 
      value="{{insertDeviceId}}" 
      placeholder="例如：v4-1" 
      bindinput="onInsertDeviceIdInput" />
    <view class="track-subtitle">请输入LoRa数据（lorastr）</view>
    <input class="track-input" 
      value="{{insertLorastr}}" 
      placeholder="例如：1|v3-1|26.000000,109.360000|1" 
      bindinput="onInsertLorastrInput" />
    <view class="track-btns">
      <button class="track-btn track-btn-gray" bindtap="onInsertClose">取消</button>
      <button class="track-btn track-btn-confirm" bindtap="onInsertConfirm">确认插入</button>
    </view>
  </view>
</view>

<!-- 查看设备轨迹弹窗 -->
<view class="track-modal" wx:if="{{showTrackModal}}">
  <view class="track-mask" bindtap="onTrackClose"></view>
  <view class="track-dialog">
    <view class="track-close" bindtap="onTrackClose">✕</view>
    <view class="track-title">查看设备轨迹</view>
    <view class="track-subtitle">选择设备ID</view>
    <picker mode="selector" range="{{deviceIdList}}" value="{{trackDeviceIdIndex}}" bindchange="onTrackDeviceIdChange">
      <view class="track-date-picker">{{trackDeviceId || '请先获取设备最新数据'}}</view>
    </picker>
    <view class="track-date-label">选择日期</view>
    <picker mode="date" value="{{trackDate}}" bindchange="onTrackDateChange">
      <view class="track-date-picker">{{trackDate}}</view>
    </picker>
    <view class="track-btns">
      <button class="track-btn track-btn-gray" bindtap="onTrackClose">取消</button>
      <button class="track-btn track-btn-confirm" bindtap="onTrackConfirm">查看数据</button>
    </view>
  </view>
</view>
