/**bluetooth.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}
.scrollarea {
  flex: 1;
}

/* 蓝牙按钮区 */
.btn-bar {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
  margin-top: 10px;
}

.btn-bluetooth {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  background: #07c160;
  border-radius: 12rpx;
  border: none;
  padding: 0;
}

.btn-bluetooth::after {
  border: none;
}

.btn-reconnect {
  background: #ffa500;
}

.btn-sync {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  background: #1989fa;
  border-radius: 12rpx;
  border: none;
  padding: 0;
}

.btn-sync::after {
  border: none;
}

.btn-disabled {
  background: #ccc;
  color: #999;
}

.btn-stop {
  background: #ee0a24 !important;
}

/* 已连接提示 */
.connected-tip {
  margin: 0 24rpx 12rpx;
  padding: 14rpx 24rpx;
  font-size: 26rpx;
  color: #07c160;
  background: #e8f8e8;
  border-radius: 10rpx;
  text-align: center;
}

/* 接收消息面板 */
.msg-panel {
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border-left: 6rpx solid #1989fa;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.msg-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.msg-content {
  font-size: 30rpx;
  color: #333;
  word-break: break-all;
  line-height: 1.6;
}

.msg-content-sm {
  font-size: 24rpx;
}

/* 设备列表面板 */
.device-panel {
  margin: 0 24rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.device-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.device-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.device-item {
  display: flex;
  align-items: center;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.device-item:last-child {
  border-bottom: none;
}

.device-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.device-info {
  flex: 1;
}

.device-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.device-id {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.device-signal {
  flex-shrink: 0;
}

.signal-db {
  font-size: 24rpx;
  color: #1989fa;
  background: #eaf3ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.device-stop {
  margin-top: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}
