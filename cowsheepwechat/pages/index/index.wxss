/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}
.scrollarea {
  flex: 1;
}

/* 摘要卡片 */
.summary-card {
  margin: 24rpx 24rpx 0;
  padding: 28rpx 28rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.summary-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.summary-icon-device {
  background: #e3f2fd;
}
.summary-icon-livestock {
  background: #fbe9e7;
}

.summary-info {
  flex: 1;
}

.summary-count {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.summary-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 统计告警卡片 */
.alert-card {
  margin: 24rpx 24rpx 0;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.alert-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.alert-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
}
.alert-item:last-child {
  padding-bottom: 0;
}

.alert-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.alert-icon {
  font-size: 30rpx;
  flex-shrink: 0;
}

.alert-text {
  font-size: 26rpx;
  color: #555;
  flex: 1;
}

.section-placeholder {
  height: 180rpx;
}

/* 快捷功能区（固定底部） */
.section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 24rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #f5f5f5;
  z-index: 100;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0 24rpx;
  text-align: center;
}

.section .btn-bar {
  display: flex;
  padding: 0;
  justify-content: center;
  gap: 32rpx;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.icon-label {
  font-size: 22rpx;
  color: #999;
}

.btn-features {
  width: 100rpx;
  height: 100rpx;
  min-width: 100rpx;
  max-width: 100rpx;
  line-height: 100rpx;
  font-size: 48rpx;
  color: #fff;
  background: #ff9500;
  border-radius: 50%;
  border: none;
  padding: 0;
  box-sizing: border-box;
  margin: 0;
}

.btn-features::after {
  border: none;
}

.btn-livestock {
  width: 100rpx;
  height: 100rpx;
  min-width: 100rpx;
  max-width: 100rpx;
  line-height: 100rpx;
  font-size: 48rpx;
  color: #fff;
  background: #8B5E3C;
  border-radius: 50%;
  border: none;
  padding: 0;
  box-sizing: border-box;
  margin: 0;
}

.btn-livestock::after {
  border: none;
}

.btn-device {
  width: 100rpx;
  height: 100rpx;
  min-width: 100rpx;
  max-width: 100rpx;
  line-height: 100rpx;
  font-size: 48rpx;
  color: #fff;
  background: #1565c0;
  border-radius: 50%;
  border: none;
  padding: 0;
  box-sizing: border-box;
  margin: 0;
}

.btn-device::after {
  border: none;
}

.btn-map {
  width: 100rpx;
  height: 100rpx;
  min-width: 100rpx;
  max-width: 100rpx;
  line-height: 100rpx;
  font-size: 48rpx;
  color: #fff;
  background: #2e7d32;
  border-radius: 50%;
  border: none;
  padding: 0;
  box-sizing: border-box;
  margin: 0;
}

.btn-map::after {
  border: none;
}

/* ========== IoT 新数据飘窗通知 ========== */
.iot-notify {
  position: fixed;
  top: 88rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 999;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #1565c0, #1e88e5);
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(21, 101, 192, 0.4);
  transform: translateY(calc(-100% - 88rpx));
  opacity: 0;
  pointer-events: none;
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease;
}
.iot-notify-show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}
.iot-notify-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  align-self: flex-start;
}
.iot-notify-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.iot-notify-line1 {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}
.iot-notify-line2 {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}
.iot-notify-line3 {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.65);
}
