<!--index.wxml-->
<navigation-bar title="牛羊显示" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <!-- 设备摘要 -->
  <view class="summary-card" bindtap="goToDevice">
    <view class="summary-icon summary-icon-device">📡</view>
    <view class="summary-info">
      <view class="summary-count">{{deviceCount}} 台设备</view>
      <view class="summary-detail" wx:if="{{deviceUpdateTime}}">最后更新 {{deviceUpdateTime}}</view>
    </view>
  </view>

  <!-- 牛羊摘要 -->
  <view class="summary-card" bindtap="goToLivestock">
    <view class="summary-icon summary-icon-livestock">🐮</view>
    <view class="summary-info">
      <view class="summary-count">{{livestockCount}} 头牛羊</view>
      <view class="summary-detail">已有 {{boundCount}} 头连接设备</view>
    </view>
  </view>

  <!-- 统计告警 -->
  <view class="alert-card">
    <view class="alert-title">📋 统计信息</view>
    <view class="alert-item" wx:for="{{alerts}}" wx:key="text">
      <view class="alert-dot" style="background:{{item.color}}"></view>
      <text class="alert-icon">{{item.icon}}</text>
      <text class="alert-text">{{item.text}}</text>
    </view>
  </view>

  <view class="section-placeholder"></view>
</scroll-view>

<!-- 快捷功能（固定在页面底部） -->
<view class="section">
  <view class="section-title">快捷功能</view>
  <view class="btn-bar">
    <view class="icon-item">
      <button class="btn-features" bindtap="goToFeatures">🛠️</button>
      <text class="icon-label">功能</text>
    </view>
    <view class="icon-item">
      <button class="btn-livestock" bindtap="goToLivestock">🐮</button>
      <text class="icon-label">牛羊管理</text>
    </view>
    <view class="icon-item">
      <button class="btn-device" bindtap="goToDevice">📡</button>
      <text class="icon-label">设备管理</text>
    </view>
  </view>
</view>
