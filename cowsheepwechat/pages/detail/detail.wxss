/**detail.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.detail-scroll {
  flex: 1;
  overflow-y: auto;
}

/* 大头像区域 */
.avatar-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  margin: 0 32rpx;
  background: linear-gradient(180deg, #e8f5e9 0%, #f5f5f5 100%);
  border-radius: 20rpx;
}

.detail-avatar {
  width: 100%;
  height: 520rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  background: #eee;
}

.detail-avatar-placeholder {
  width: 360rpx;
  height: 360rpx;
  border-radius: 24rpx;
  background: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 180rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* 设备下拉选择（信息卡片内） */
.info-picker {
  flex: 1;
}

.info-picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
}

.info-arrow {
  font-size: 22rpx;
  color: #999;
}

/* 信息卡片 */
.info-card {
  margin: 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.info-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* 性别标签 */
.gender-tag {
  font-size: 26rpx;
  font-weight: 500;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
}

.gender-male {
  color: #1565c0;
  background: #e3f2fd;
}

.gender-female {
  color: #c62828;
  background: #ffebee;
}

/* 获取更多图像按钮 */
.fetch-media-btn {
  margin: 32rpx 24rpx 0;
  background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(67, 160, 71, 0.3);
}

/* 媒体展示区域 */
.media-section {
  margin: 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.media-item {
  width: calc(33.33% - 11rpx);
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.media-thumb {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  background: #eee;
}

.media-video-thumb {
  position: relative;
}

.media-play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
}

.media-unknown {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ccc;
}

.media-time {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  padding: 8rpx 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
