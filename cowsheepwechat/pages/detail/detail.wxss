/**detail.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.detail-scroll {
  flex: 1;
  overflow-y: auto;
}

/* 大头像区域 */
.avatar-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  margin: 0 32rpx;
  background: linear-gradient(180deg, #e8f5e9 0%, #f5f5f5 100%);
  border-radius: 20rpx;
}

.detail-avatar {
  width: 100%;
  height: 520rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  background: #eee;
}

.detail-avatar-placeholder {
  width: 360rpx;
  height: 360rpx;
  border-radius: 24rpx;
  background: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 180rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* 设备下拉选择（信息卡片内） */
.info-picker {
  flex: 1;
}

.info-picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
}

.info-arrow {
  font-size: 22rpx;
  color: #999;
}

/* 信息卡片 */
.info-card {
  margin: 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.info-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* 性别标签 */
.gender-tag {
  font-size: 26rpx;
  font-weight: 500;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
}

.gender-male {
  color: #1565c0;
  background: #e3f2fd;
}

.gender-female {
  color: #c62828;
  background: #ffebee;
}

/* 获取更多图像按钮 */
.fetch-media-btn {
  margin: 32rpx 24rpx 0;
  background: linear-gradient(135deg, #43a047 0%, #66bb6a 100%);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(67, 160, 71, 0.3);
}

/* 媒体展示区域 */
.media-section {
  margin: 32rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 媒体工具栏 */
.media-toolbar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.media-edit-btn {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #333;
  background: #f0f0f0;
  border: 2rpx solid #ddd;
}

.media-edit-btn:active {
  background: #e0e0e0;
}

.media-delete-btn {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
  box-shadow: 0 4rpx 12rpx rgba(229, 57, 53, 0.3);
}

.media-delete-btn:active {
  opacity: 0.85;
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.media-item {
  width: calc(33.33% - 11rpx);
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.media-item-edit {
  opacity: 0.85;
}

.media-thumb {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  background: #eee;
}

.media-video-thumb {
  position: relative;
}

/* 复选框 */
.media-checkbox {
  position: absolute;
  bottom: 36rpx;
  right: 8rpx;
  z-index: 2;
}

.checkbox-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.checkbox-checked {
  background: #07c160;
  border-color: #07c160;
}

.media-play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
}

.media-unknown {
  width: 100%;
  height: 220rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ccc;
}

.media-time {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  padding: 8rpx 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 上传按钮 */
.upload-media-btn {
  background: linear-gradient(135deg, #1565c0 0%, #42a5f5 100%) !important;
  box-shadow: 0 4rpx 16rpx rgba(21, 101, 192, 0.3) !important;
  margin-bottom: 32rpx;
}

/* ========== 弹窗 ========== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.modal-dialog {
  position: relative;
  width: 600rpx;
  max-height: 85vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
}

.modal-close {
  position: absolute;
  top: 16rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 32rpx;
  color: #999;
  border-radius: 50%;
  background: #f5f5f5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 28rpx;
}

.modal-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.modal-btns {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 10rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0;
}

.modal-btn-confirm {
  background: #07c160;
  color: #fff;
}

.modal-btn-gray {
  background: #999;
  color: #fff;
}

.modal-btn-del {
  background: #e53935;
  color: #fff;
}

/* ========== 上传图片区 ========== */
.upload-img-box {
  width: 100%;
  height: 260rpx;
  border: 3rpx dashed #b0bec5;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  overflow: hidden;
  background: #fafafa;
}

.upload-img-preview {
  width: 100%;
  height: 100%;
}

.upload-img-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-img-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.upload-img-text {
  font-size: 26rpx;
  color: #999;
}

/* ========== 视频播放弹窗 ========== */
.video-player-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.9);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-player-box {
  width: 100vw;
  position: relative;
}

.video-close-btn {
  position: absolute;
  top: -60rpx;
  right: 30rpx;
  z-index: 2;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.video-player {
  width: 100vw;
  height: 56vw;
}
