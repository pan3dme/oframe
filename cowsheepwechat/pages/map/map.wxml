<!--map.wxml-->
<navigation-bar title="地图中心" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<canvas type="2d" id="pinCanvas" style="width:40px;height:40px;position:fixed;left:-9999px"></canvas>
<canvas type="2d" id="deviceDotCanvas" style="width:30px;height:30px;position:fixed;left:-9999px"></canvas>

<movable-area class="map-area" scale-area wx:if="{{useBaidu && baiduMapUrl}}">
  <movable-view class="map-view" direction="all" scale scale-min="1" scale-max="5"
    scale-value="{{scale}}" bindscale="onScale" inertia="{{true}}" out-of-bounds="{{false}}">
    <image class="map-image" src="{{baiduMapUrl}}" mode="aspectFill" binderror="onImageError" />
  </movable-view>
</movable-area>

<map wx:if="{{showNativeMap}}" id="cowMap" class="map"
  latitude="{{nativeLat}}" longitude="{{nativeLng}}" scale="{{nativeScale}}"
  markers="{{markers}}" polyline="{{polylines}}" show-location="{{true}}" enable-satellite="{{isSatellite}}"
  bindregionchange="onRegionChange" />

<!-- 左下角图层切换按钮 -->
<view class="layer-toggle {{showRoadLayer ? 'layer-on' : ''}}" bindtap="toggleLayer">
  <text class="layer-icon">🗺️</text>
  <text class="layer-label">{{showRoadLayer ? '已开启' : '图层'}}</text>
</view>

<!-- 右下角功能按钮组 -->
<view class="map-toolbar">
  <view class="tool-btn" bindtap="moveToMyLocation">
    <text class="tool-icon">◎</text>
    <text class="tool-label">定位</text>
  </view>
  <view class="tool-btn" bindtap="onToolBtn2">
    <text class="tool-icon">↻</text>
    <text class="tool-label">刷新</text>
  </view>
  <view class="tool-btn" bindtap="nextMarker">
    <text class="tool-icon">▸</text>
    <text class="tool-label">巡点</text>
  </view>
</view>
