/**trackmap.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #222;
}

.map-area {
  flex: 1;
  width: 100%;
  overflow: hidden;
}

.map-view {
  width: 100%;
  height: 100%;
}

.map-image {
  width: 100%;
  height: 100%;
}

.map {
  flex: 1;
  width: 100%;
}

/* 右下角功能按钮组 */
.map-toolbar {
  position: fixed;
  right: 20rpx;
  bottom: 60rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 999;
}

.tool-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tool-btn:active {
  background: rgba(230, 230, 230, 0.95);
}

.tool-icon {
  font-size: 32rpx;
  color: #333;
  line-height: 1;
}

.tool-label {
  font-size: 16rpx;
  color: #666;
  margin-top: 2rpx;
}
