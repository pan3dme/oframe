/**livestock.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

/* 功能面板 */
.feature-panel {
  margin: 24rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 28rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #07c160;
}

/* 操作按钮 */
.action-btn {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: 14rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #f0faf5 0%, #e8f8ef 100%);
  border: 2rpx solid #d4edda;
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.97);
}

.add-btn {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-color: #a5d6a7;
}

.refresh-btn {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border-color: #ffcc80;
}

.refresh-btn .btn-icon {
  background: #ff9800;
}

.btn-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  border-radius: 50%;
  margin-right: 20rpx;
}

.add-btn .btn-icon {
  background: #07c160;
}

.btn-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* ========== 弹窗 ========== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.modal-dialog {
  position: relative;
  width: 600rpx;
  max-height: 85vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
}

.modal-close {
  position: absolute;
  top: 16rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 32rpx;
  color: #999;
  border-radius: 50%;
  background: #f5f5f5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 28rpx;
}

.modal-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  margin-bottom: 28rpx;
}

.modal-input-readonly {
  line-height: 80rpx;
  color: #999;
  background: #f5f5f5;
}

.modal-picker {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 28rpx;
}

.modal-btns {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 10rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0;
}

.modal-btn-confirm {
  background: #07c160;
  color: #fff;
}

.modal-btn-gray {
  background: #999;
  color: #fff;
}

/* ========== 牛羊列表 ========== */
.list-panel {
  margin: 0 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.list-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #1565c0;
}

.list-hint {
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 16rpx;
  padding-left: 14rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:active {
  background: #f5faff;
}

.list-item:last-child {
  border-bottom: none;
}

.item-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.item-avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.item-birthday {
  font-size: 24rpx;
  color: #999;
}

.item-id {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.item-device {
  font-size: 22rpx;
  color: #07c160;
  margin-top: 4rpx;
}

.item-edit-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fef3e2;
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.item-edit-btn:active {
  background: #fde0b2;
  transform: scale(0.92);
}

.item-edit-icon {
  font-size: 30rpx;
  color: #e67e22;
  font-weight: bold;
}

.item-connect-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f5e9;
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.item-connect-btn:active {
  background: #c8e6c9;
  transform: scale(0.92);
}

.item-connect-icon {
  font-size: 32rpx;
}

.item-gender {
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.gender-male {
  color: #1565c0;
  background: #e3f2fd;
}

.gender-female {
  color: #c62828;
  background: #ffebee;
}

/* ========== 修改面板头像 ========== */
.edit-avatar-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-bottom: 28rpx;
  position: relative;
  overflow: hidden;
  border: 3rpx dashed #b0bec5;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
}

.edit-avatar-placeholder {
  font-size: 72rpx;
}

.edit-avatar-tag {
  position: absolute;
  top: 0;
  right: 0;
  background: #07c160;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 14rpx 0 14rpx;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  font-size: 28rpx;
  color: #bbb;
  padding: 40rpx 0;
}
