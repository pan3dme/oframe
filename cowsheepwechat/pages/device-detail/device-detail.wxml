<!--device-detail.wxml-->
<navigation-bar title="设备详情" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <block wx:if="{{deviceInfo}}">
    <!-- 设备图片 -->
    <view class="pic-area">
      <image class="detail-pic" wx:if="{{deviceInfo.picurl}}" src="{{deviceInfo.picurl}}" mode="aspectFill" />
      <view class="detail-pic-placeholder" wx:else>📡</view>
    </view>

    <!-- 设备信息卡片 -->
    <view class="info-card">
      <view class="info-row">
        <text class="info-label">deviceId</text>
        <text class="info-value">{{deviceInfo.deviceId}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">别名</text>
        <text class="info-value">{{deviceInfo.rename || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">设备编码</text>
        <text class="info-value">{{deviceInfo.device_key || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">Lora串</text>
        <text class="info-value">{{deviceInfo.lorastr || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">绑定牛羊</text>
        <text class="info-value">{{deviceInfo.bindName || deviceInfo.link_cowsheep_id || '未绑定'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">记录时间</text>
        <text class="info-value">{{deviceInfo.date}} {{deviceInfo.time_part}}</text>
      </view>
    </view>

    <!-- 查看设备记录按钮 -->
    <view class="record-btn" bindtap="onViewRecords">
      <text>查看设备轨迹</text>
    </view>

    <!-- 轨迹数据表格 -->
    <view class="msg-panel" wx:if="{{showRecordTable}}">
      <view class="record-table">
        <view class="table-header">
          <view class="th th-deviceId">deviceId</view>
          <view class="th th-lorastr">lorastr</view>
          <view class="th th-time">time</view>
        </view>
        <view class="table-body">
          <view class="table-row" wx:for="{{recordList}}" wx:key="rawTime">
            <view class="td td-deviceId">{{item.deviceId}}</view>
            <view class="td td-lorastr">{{item.lorastr}}</view>
            <view class="td td-time">
              <view class="time-date">{{item.date}}</view>
              <view class="time-clock">{{item.time_part}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 加载中 -->
  <view class="empty-tip" wx:else>加载中...</view>
</scroll-view>

<!-- 设备轨迹日期选择弹窗 -->
<view class="track-modal" wx:if="{{showTrackModal}}">
  <view class="track-mask" bindtap="onTrackClose"></view>
  <view class="track-dialog">
    <view class="track-close" bindtap="onTrackClose">✕</view>
    <view class="track-title">查看设备轨迹</view>
    <view class="track-subtitle">设备：{{deviceId}}</view>
    <view class="track-date-label">选择日期</view>
    <picker mode="date" value="{{trackDate}}" bindchange="onTrackDateChange">
      <view class="track-date-picker">{{trackDate}}</view>
    </picker>
    <view class="track-btns">
      <button class="track-btn track-btn-confirm" bindtap="onTrackConfirm">列出数据</button>
      <button class="track-btn track-btn-map" bindtap="onTrackShowMap">轨迹地图</button>
    </view>
  </view>
</view>
