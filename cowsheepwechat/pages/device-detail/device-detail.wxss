/**device-detail.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

/* 图片区域 */
.pic-area {
  width: 100%;
  height: 420rpx;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-pic {
  width: 100%;
  height: 100%;
}
.detail-pic-placeholder {
  font-size: 120rpx;
  color: #bbb;
}

/* 信息卡片 */
.info-card {
  margin: 24rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

/* 查看记录按钮 */
.record-btn {
  margin: 24rpx 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #1565c0;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 14rpx;
}
.record-btn:active {
  opacity: 0.8;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  font-size: 28rpx;
  color: #bbb;
  padding: 100rpx 0;
}

/* ========== 设备轨迹日期选择弹窗 ========== */
.track-modal {
  position: fixed;
  z-index: 999;
  left: 0; right: 0; top: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.track-mask {
  position: absolute;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}
.track-dialog {
  position: relative;
  z-index: 2;
  width: 620rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 36rpx 32rpx;
}
.track-close {
  position: absolute;
  top: 16rpx; right: 24rpx;
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}
.track-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}
.track-subtitle {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 28rpx;
  word-break: break-all;
}
.track-date-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.track-date-picker {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 32rpx;
}
.track-btns {
  display: flex;
  gap: 20rpx;
}
.track-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
  border: none;
  margin: 0;
  box-sizing: border-box;
}
.track-btn::after {
  border: none;
}
.track-btn-gray {
  background: #f0f0f0;
  color: #666;
}
.track-btn-confirm {
  background: #07c160;
  color: #fff;
}
.track-btn-map {
  background: #1565c0;
  color: #fff;
}

/* ========== 轨迹数据表格 ========== */
.msg-panel {
  margin: 0 20rpx 24rpx;
}

.record-table {
  border-radius: 10rpx;
  overflow: hidden;
  border: 1rpx solid #e0e0e0;
}

.table-header {
  display: flex;
  background: #f0f6ff;
  font-weight: bold;
  font-size: 26rpx;
  color: #1a6fb5;
}

.table-body {
  font-size: 26rpx;
  color: #333;
}

.table-row {
  display: flex;
  align-items: center;
}
.table-row:nth-child(even) {
  background: #fafbfc;
}

.th, .td {
  padding: 16rpx 12rpx;
  word-break: break-all;
  line-height: 1.4;
  box-sizing: border-box;
}
.th {
  border-bottom: 2rpx solid #d0ddf0;
}
.td {
  border-bottom: 1rpx solid #eee;
}

.th-deviceId, .td-deviceId {
  width: 16%;
  text-align: center;
}
.th-lorastr, .td-lorastr {
  width: 49%;
  text-align: center;
}
.th-time, .td-time {
  width: 35%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.time-date {
  font-size: 22rpx;
  color: #666;
  line-height: 1.3;
}
.time-clock {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.3;
}
