/**device-detail.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

/* 图片区域 */
.pic-area {
  width: 100%;
  height: 420rpx;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.detail-pic {
  width: 100%;
  height: 100%;
}
.detail-pic-placeholder {
  font-size: 120rpx;
  color: #bbb;
}

/* 信息卡片 */
.info-card {
  margin: 24rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

/* 查看记录按钮 */
.record-btn {
  margin: 24rpx 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #1565c0;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 14rpx;
}
.record-btn:active {
  opacity: 0.8;
}

/* 记录摘要 */
.record-summary {
  margin: 0 20rpx 8rpx;
  padding: 16rpx 24rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1565c0;
  font-weight: 500;
}

/* 记录卡片 */
.record-item {
  margin: 16rpx 20rpx;
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.rec-row {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.rec-row:last-child {
  border-bottom: none;
}

.rec-label {
  width: 180rpx;
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.rec-value {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  font-size: 28rpx;
  color: #bbb;
  padding: 100rpx 0;
}
