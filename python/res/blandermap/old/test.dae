  <library_effects>
    <effect id="BuildingMat-00056-effect">
      <profile_COMMON>
        <newparam sid="_-00056-texture_png-surface">
          <surface type="2D">
            <init_from>_-00056-texture_png</init_from>
          </surface>
        </newparam>
        <newparam sid="_-00056-texture_png-sampler">
